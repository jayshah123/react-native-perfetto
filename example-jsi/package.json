{
  "name": "react-native-perfetto-example-jsi",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "ios": "yarn ios:new-arch",
    "ios:new-arch": "RCT_NEW_ARCH_ENABLED=1 react-native run-ios",
    "ios:old-arch": "RCT_NEW_ARCH_ENABLED=0 react-native run-ios",
    "start": "react-native start",
    "build:android": "react-native build-android --extra-params \"--no-daemon --console=plain -PreactNativeArchitectures=arm64-v8a\"",
    "build:ios": "yarn build:ios:new-arch",
    "build:ios:new-arch": "RCT_NEW_ARCH_ENABLED=1 react-native build-ios --mode Debug",
    "build:ios:old-arch": "RCT_NEW_ARCH_ENABLED=0 react-native build-ios --mode Debug",
    "build:ios:ci": "yarn build:ios:ci:new-arch",
    "build:ios:ci:new-arch": "RCT_NEW_ARCH_ENABLED=1 react-native build-ios --mode Debug --force-pods --verbose --extra-params \"-resultBundlePath build/ci-build.xcresult\"",
    "build:ios:ci:old-arch": "RCT_NEW_ARCH_ENABLED=0 react-native build-ios --mode Debug --force-pods --verbose --extra-params \"-resultBundlePath build/ci-build-old-arch.xcresult\""
  },
  "dependencies": {
    "react": "19.2.0",
    "react-native": "0.83.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "20.0.0",
    "@react-native-community/cli-platform-android": "20.0.0",
    "@react-native-community/cli-platform-ios": "20.0.0",
    "@react-native/babel-preset": "0.83.0",
    "@react-native/metro-config": "0.83.0",
    "@react-native/typescript-config": "0.83.0",
    "@types/react": "^19.2.0",
    "react-native-builder-bob": "^0.40.18",
    "react-native-monorepo-config": "^0.3.3"
  },
  "engines": {
    "node": ">=20"
  }
}
